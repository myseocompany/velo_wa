APP_NAME=AriCRM
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=velo
DB_USERNAME=velo
DB_PASSWORD=secret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
AI_AGENT_QUEUE=default

CACHE_STORE=redis
CACHE_PREFIX=velo_

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (Mailpit for local dev)
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@aricrm.app"
MAIL_FROM_NAME="${APP_NAME}"

# S3 / MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=velo-media
AWS_ENDPOINT=http://127.0.0.1:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Evolution API (WhatsApp bridge)
EVOLUTION_API_URL=http://127.0.0.1:8081
EVOLUTION_API_KEY=changeme

# Laravel Reverb (WebSockets)
REVERB_APP_ID=velo
REVERB_APP_KEY=velo-key
REVERB_APP_SECRET=velo-secret
# Internal host/port used by Laravel to publish events to Reverb.
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SERVER_PORT=6001
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
# Public host/port exposed to the browser. In production these usually
# point to your HTTPS app domain / reverse proxy, not to localhost.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:8000,localhost:8002,localhost:5173,127.0.0.1:8000,127.0.0.1:8002,127.0.0.1:5173

# Horizon
HORIZON_PREFIX=velo_horizon:

# Stripe / Cashier
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en

# Stripe Price IDs
STRIPE_PRICE_SEED=price_
STRIPE_PRICE_GROW=price_
STRIPE_PRICE_SCALE=price_
