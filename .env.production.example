# ─────────────────────────────────────────────────────────────────────────────
# AriCRM — Production Environment Template
# Copy to .env and fill in real values before deploying.
# NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=AriCRM
APP_ENV=production
APP_KEY=                             # php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://YOUR_DOMAIN

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=cache

BCRYPT_ROUNDS=12

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily,slack              # Fan out to file + Slack for errors
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                  # Only warning+ in production
LOG_DAILY_DAYS=30
LOG_SLACK_WEBHOOK_URL=             # Your Slack incoming webhook URL
LOG_SLACK_USERNAME=AriCRM
LOG_SLACK_LEVEL=error

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres                   # Docker service name
DB_PORT=5432
DB_DATABASE=velo
DB_USERNAME=velo
DB_PASSWORD=                       # Strong password — min 32 chars

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480               # 8 hours
SESSION_ENCRYPT=true
SESSION_DOMAIN=YOUR_DOMAIN

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=velo_

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis              # Use phpredis in production (faster)
REDIS_HOST=redis                   # Docker service name
REDIS_PASSWORD=                    # Set a strong Redis password
REDIS_PORT=6379

# ── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@YOUR_DOMAIN"
MAIL_FROM_NAME="${APP_NAME}"

# ── S3 / AWS ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=aricrm-media
# AWS_ENDPOINT=                    # Leave blank for real AWS S3
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Stripe Billing ────────────────────────────────────────────────────────────
STRIPE_KEY=pk_live_               # Stripe publishable key
STRIPE_SECRET=sk_live_            # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_      # From Stripe dashboard → Webhooks
STRIPE_PRICE_STARTER=price_       # Stripe Price ID for Starter plan
STRIPE_PRICE_GROWTH=price_        # Stripe Price ID for Growth plan
STRIPE_PRICE_SCALE=price_         # Stripe Price ID for Scale plan

# ── Evolution API (WhatsApp) ──────────────────────────────────────────────────
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=                 # Minimum 32 chars, random

# Used in docker-compose.prod.yml for webhook URL construction
EVOLUTION_SERVER_URL=https://YOUR_DOMAIN/evolution

# ── Laravel Reverb (WebSockets) ───────────────────────────────────────────────
REVERB_APP_ID=                     # Random string e.g. aricrm_prod
REVERB_APP_KEY=                    # Random string, 32+ chars
REVERB_APP_SECRET=                 # Random string, 32+ chars
REVERB_HOST=YOUR_DOMAIN
REVERB_PORT=443
REVERB_SCHEME=https

# Vite (built into assets at build time — use production domain)
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=YOUR_DOMAIN

# ── Horizon ───────────────────────────────────────────────────────────────────
HORIZON_PREFIX=velo_horizon:

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_S3_BUCKET=aricrm-backups
BACKUP_S3_PREFIX=db
BACKUP_RETAIN_DAYS=30
